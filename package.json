{
  "name": "magic-academy-adventure-next",
  "private": true,
  "license": "UNLICENSED",
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "description": "Local-first browser and Electron runtime for the STARFALL MAGIC ACADEMY playable development project.",
  "scripts": {
    "test": "node --test app/tests/*.test.mjs",
    "check": "node --check electron/main.mjs && node --check app/src/*.mjs && node --check app/src/llm/*.mjs && node --check app/src/dungeon/*.mjs && node --check app/src/arena/*.mjs && node --check app/src/electron/*.mjs && node --check app/src/server/*.mjs && node --check app/public/app.js",
    "start": "node app/src/server.mjs",
    "electron": "electron .",
    "electron:dev": "MAGIC_ACADEMY_ELECTRON_DEVTOOLS=1 electron .",
    "electron:dist": "electron-builder --dir",
    "electron:mac": "electron-builder --mac dmg zip",
    "electron:win": "electron-builder --win nsis --x64",
    "electron:pack": "electron-builder",
    "lint": "npm run check",
    "import:scan": "node --test app/tests/runtimePaths.test.mjs"
  },
  "devDependencies": {
    "@electron/osx-sign": "^1.3.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "com.uyuris.magic-academy-adventure-next",
    "productName": "STARFALL MAGIC ACADEMY",
    "asar": true,
    "icon": "assets/app-icons/sera-neutral.icns",
    "files": [
      "app/**/*",
      "assets/**/*",
      "!assets/original/**",
      "content/**/*",
      "data/definitions/**/*",
      "data/seeds/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/legal/third-party-notices",
        "to": "third-party-notices",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "mac": {
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "strictVerify": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "forceCodeSigning": true,
      "preAutoEntitlements": false,
      "timestamp": "none",
      "sign": "scripts/sign-macos.mjs"
    },
    "win": {
      "icon": "assets/app-icons/sera-neutral.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
